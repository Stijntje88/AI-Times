<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AI_Times.View.Home.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AI_Times.Data.Models"
    xmlns:converters="using:AI_Times.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with logo and tagline -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                Padding="20,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/AI-Times-Logo-Inside-App.png"
                       Height="96"
                       Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <ListView x:Name="ArticlesListView"
                   Grid.Row="1"
                   ItemsSource="{x:Bind Articles}"
                   SelectionMode="Single"
                   ItemClick="ArticlesListView_ItemClick"
                   IsItemClickEnabled="True"
                   Margin="20">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:NewspaperArticle">
                    <Grid Margin="0,10" Padding="15" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                          CornerRadius="8" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1"
                          PointerEntered="ArticleCard_PointerEntered"
                          PointerExited="ArticleCard_PointerExited">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Article Image -->
                        <Border Grid.Column="0"
                                Width="100"
                                Height="100"
                                CornerRadius="4"
                                VerticalAlignment="Top">
                            <Image Source="{Binding Image1, Converter={StaticResource ImageUrlConverter}}"
                                   Stretch="Uniform"/>
                        </Border>

                        <!-- Article Content -->
                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="{x:Bind Title}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="{x:Bind Introduction}"
                                       FontSize="14"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <TextBlock Text="{x:Bind Author}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind FormattedPublishDate}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
