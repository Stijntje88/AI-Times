<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AI_Times.View.Home.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AI_Times.Data.Models"
    xmlns:converters="using:AI_Times.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header with logo and tagline -->
        <Border Grid.Row="0"
                Background="{ThemeResource SystemControlAcrylicWindowBrush}"
                Padding="20,16">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Image Source="ms-appx:///Assets/AI-Times-Logo-Inside-App.png"
                       Height="96"
                       Stretch="Uniform"/>
            </StackPanel>
        </Border>

        <!-- News Genres Header -->
        <ScrollViewer Grid.Row="1" HorizontalScrollMode="Enabled" HorizontalScrollBarVisibility="Auto" VerticalScrollMode="Disabled" Margin="20,0,20,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Breaking News" Tag="Breaking News" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Political News" Tag="Political News" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Business and Economic" Tag="Business and Economic" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="International (World)" Tag="International (World)" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Technology News" Tag="Technology News" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Science and Health" Tag="Science and Health" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Sports News" Tag="Sports News" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Entertainment and Culture" Tag="Entertainment and Culture" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Lifestyle and Human-Interest" Tag="Lifestyle and Human-Interest" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
                <Button Content="Investigative Journalism" Tag="Investigative Journalism" Click="GenreButton_Click" Background="#002244" Foreground="White" CornerRadius="8" Padding="16,8" FontSize="16" FontWeight="SemiBold" />
            </StackPanel>
        </ScrollViewer>

        <ListView x:Name="ArticlesListView"
                   Grid.Row="2"
                   ItemsSource="{x:Bind Articles}"
                   SelectionMode="Single"
                   ItemClick="ArticlesListView_ItemClick"
                   IsItemClickEnabled="True"
                   Margin="20">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:NewspaperArticle">
                    <Grid Margin="0,10" Padding="0,0,0,20" Background="Transparent"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1"
                          PointerEntered="ArticleCard_PointerEntered"
                          PointerExited="ArticleCard_PointerExited">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Article Content -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <!-- Category or Kicker could go here if available -->
                            
                            <TextBlock Text="{x:Bind Title}"
                                       FontFamily="Georgia, Times New Roman, serif"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="{x:Bind Introduction}"
                                       FontFamily="Georgia, Times New Roman, serif"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind Author}"
                                           FontFamily="Segoe UI, sans-serif"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="&#x2022;"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind Genre}"
                                           FontFamily="Segoe UI, sans-serif"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="&#x2022;"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind FormattedPublishDate}"
                                           FontFamily="Segoe UI, sans-serif"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Article Image -->
                        <Border Grid.Column="1"
                                Width="200"
                                Height="150"
                                VerticalAlignment="Top">
                            <Image Source="{Binding Image1, Converter={StaticResource ImageUrlConverter}}"
                                   Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
