<Page
    x:Class="AI_Times.View.Home.ArticleDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:AI_Times.Data.Models"
    xmlns:converters="using:AI_Times.View.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlConverter" />
        <converters:ParagraphSpacingConverter x:Key="ParagraphConverter" />
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Spacing="24" Padding="40,20,40,40" MaxWidth="800" HorizontalAlignment="Center">
            <Button Content="? Back"
                    Background="Transparent"
                    BorderThickness="0"
                    HorizontalAlignment="Left"
                    Click="BackButton_Click" 
                    Margin="0,0,0,20"/>

            <TextBlock Text="{x:Bind Article.Title, Mode=OneWay}"
                       FontSize="42"
                       FontWeight="SemiBold"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <StackPanel Orientation="Horizontal" Spacing="20" Opacity="0.7">
                <TextBlock Text="{x:Bind Article.Author, Mode=OneWay}"
                           FontSize="14" 
                           FontWeight="Medium"/>
                <TextBlock Text="•" FontSize="14"/>
                <TextBlock Text="{x:Bind Article.Genre, Mode=OneWay}"
                           FontSize="14" 
                           FontWeight="Medium"/>
                <TextBlock Text="•" FontSize="14"/>
                <TextBlock Text="{x:Bind Article.FormattedPublishDate, Mode=OneWay}"
                           FontSize="14" />
            </StackPanel>

            <Grid CornerRadius="8" MaxHeight="400" Margin="0,10,0,10">
                <Image Source="{x:Bind Article.Image1, Mode=OneWay, Converter={StaticResource ImageUrlConverter}}"
                       Stretch="UniformToFill" />
            </Grid>

            <TextBlock Text="{x:Bind Article.Subtitle1, Mode=OneWay}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <TextBlock Text="{x:Bind Article.Introduction, Mode=OneWay, Converter={StaticResource ParagraphConverter}}"
                       FontSize="18"
                       LineHeight="28"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <TextBlock Text="{x:Bind Article.Subtitle2, Mode=OneWay}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <TextBlock Text="{x:Bind Article.MiddleSection, Mode=OneWay, Converter={StaticResource ParagraphConverter}}"
                       FontSize="18"
                       LineHeight="28"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <Grid CornerRadius="8" MaxHeight="400" Margin="0,10,0,10">
                <Image Source="{x:Bind Article.Image2, Mode=OneWay, Converter={StaticResource ImageUrlConverter}}"
                       Stretch="UniformToFill" />
            </Grid>

            <TextBlock Text="{x:Bind Article.Subtitle3, Mode=OneWay}"
                       FontSize="24"
                       FontWeight="SemiBold"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />

            <TextBlock Text="{x:Bind Article.Conclusion, Mode=OneWay, Converter={StaticResource ParagraphConverter}}"
                       FontSize="18"
                       LineHeight="28"
                       FontFamily="Georgia"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</Page>
