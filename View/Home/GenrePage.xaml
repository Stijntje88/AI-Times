<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="AI_Times.View.Home.GenrePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AI_Times.Data.Models"
    xmlns:converters="using:AI_Times.View.Converters">

    <Page.Resources>
        <converters:ImageUrlToBitmapImageConverter x:Key="ImageUrlConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="20" Background="{ThemeResource SystemControlAcrylicWindowBrush}">
            <Button Content="Back" Click="BackButton_Click" Margin="0,0,20,0" Style="{StaticResource NavigationBackButtonNormalStyle}"/>
            <TextBlock x:Name="GenreTitleText" FontSize="32" FontWeight="Bold" VerticalAlignment="Center" />
        </StackPanel>

        <ListView x:Name="ArticlesListView"
                   Grid.Row="1"
                   ItemsSource="{x:Bind Articles}"
                   SelectionMode="Single"
                   ItemClick="ArticlesListView_ItemClick"
                   IsItemClickEnabled="True"
                   Margin="20">
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="local:NewspaperArticle">
                    <Grid Margin="0,10" Padding="0,0,0,20" Background="Transparent"
                          BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                          BorderThickness="0,0,0,1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <!-- Article Content -->
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            
                            <TextBlock Text="{x:Bind Title}"
                                       FontFamily="Georgia, Times New Roman, serif"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            
                            <TextBlock Text="{x:Bind Introduction}"
                                       FontFamily="Georgia, Times New Roman, serif"
                                       FontSize="15"
                                       TextWrapping="Wrap"
                                       MaxLines="3"
                                       TextTrimming="CharacterEllipsis"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,12"/>
                            
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{x:Bind Author}"
                                           FontFamily="Segoe UI, sans-serif"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="&#x2022;"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                                <TextBlock Text="{x:Bind FormattedPublishDate}"
                                           FontFamily="Segoe UI, sans-serif"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Article Image -->
                        <Border Grid.Column="1"
                                Width="200"
                                Height="150"
                                VerticalAlignment="Top">
                            <Image Source="{Binding Image1, Converter={StaticResource ImageUrlConverter}}"
                                   Stretch="UniformToFill"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
