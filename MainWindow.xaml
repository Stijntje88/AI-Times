<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="AI_Times.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:AI_Times"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="AI-Times">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Frame x:Name="contentFrame" />
        
        <Grid x:Name="LoadingOverlay" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                <Image Source="ms-appx:///Assets/AI-Times-Logo - Outside-App.png" Height="150" Stretch="Uniform" />
                <ProgressBar x:Name="LoadingProgressBar" IsIndeterminate="False" Minimum="0" Maximum="100" Value="0" Width="200" Height="4" />
                <TextBlock x:Name="LoadingText" Text="Starting up..." HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
